# ── ClaimIntel — API Keys ──────────────────────────────────────────────────────
# Copy this file to .env and fill in your keys before running docker compose up

# Groq API  (free — https://console.groq.com)
# Powers all 5 agents: text LLM + vision LLM
GROQ_API_KEY=your_groq_key_here

# Google Gemini  (optional — only needed if switching back from Groq)
GEMINI_API_KEY=your_gemini_key_here

# OpenWeatherMap  (free tier — https://openweathermap.org/api)
# Used by Agent 4 (Context Verification) for live weather at incident location
OPENWEATHERMAP_API_KEY=your_owm_key_here
